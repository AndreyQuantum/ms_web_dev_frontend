# Frontend → Backend microservices.
# These are baked into the Vite bundle at build time (import.meta.env.VITE_*).
# Defaults assume same-origin reverse-proxy paths (nginx in the frontend container).
# For Vite dev server (npm run dev), vite.config.ts proxies the same paths to localhost:8002 / :8003.

VITE_PRODUCTS_API_URL=/api/products
VITE_ORDERS_API_URL=/api/orders

# Postgres credentials used by docker-compose (dev defaults — override in production).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
